# AlmiKorean env template. Copy to .env (git-ignored). Never commit real secrets.

# Neon Postgres. Runtime uses the POOLED host and MUST carry pgbouncer=true (network gotcha).
DATABASE_URL="postgresql://USER:PASSWORD@POOLED-HOST/DB?sslmode=require&pgbouncer=true"
# Direct (unpooled) host for prisma migrations.
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@DIRECT-HOST/DB?sslmode=require"

APP_URL="https://almikorean.almiworld.com"

# Access tiers (comma-separated emails). OWNER = unlimited/premium bypass; ADMIN = /admin panel.
OWNER_EMAILS="almiworld@almiworld.com"
ADMIN_EMAILS="almiworld@almiworld.com"

# Billing (Stripe). Billing stays OFF (fail-closed) until BOTH the secret key and price id are set.
# Founder creates the "AlmiKorean Pro" product ($12/mo, 7-day trial) in the shared AlmiWorld Stripe account.
STRIPE_SECRET_KEY=""
STRIPE_PRICE_ID=""
STRIPE_WEBHOOK_SECRET=""
